# ===========================================
# DATABASE (Neon PostgreSQL)
# ===========================================
# Obtener de: https://console.neon.tech
# Formato: postgresql://user:password@host/database?sslmode=require
DATABASE_URL="postgresql://..."

# ===========================================
# BETTER AUTH
# ===========================================
# Generar secret con: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-min-32-chars-here"

# URL base de la aplicación
BETTER_AUTH_URL="http://localhost:3000"

# ===========================================
# STRIPE
# ===========================================
# Obtener de: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook secret (Stripe Dashboard > Webhooks > Signing secret)
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs de tus productos en Stripe
STRIPE_PRICE_FREE="price_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

# ===========================================
# APPLICATION
# ===========================================
# Desarrollo local:
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Producción (ej: https://crmdev.tech/):
# NEXT_PUBLIC_APP_URL="https://crmdev.tech"

NEXT_PUBLIC_APP_NAME="CRMPro"

# MCP Public URL (para integraciones con Claude, ChatGPT, etc.)
# Debe ser la misma que NEXT_PUBLIC_APP_URL sin barra al final
NEXT_PUBLIC_MCP_PUBLIC_URL="http://localhost:3000"
# Producción:
# NEXT_PUBLIC_MCP_PUBLIC_URL="https://crmdev.tech"

# ===========================================
# AI ASSISTANT (OpenAI)
# ===========================================
# API key de OpenAI para el asistente de IA
# Obtener de: https://platform.openai.com/api-keys
# NOTA: Esta es la key por defecto del sistema. Cada organización puede tener la suya.
OPENAI_API_KEY="sk-..."

# ===========================================
# EMAIL (Resend - opcional)
# ===========================================
# Obtener de: https://resend.com/api-keys
RESEND_API_KEY="re_..."
EMAIL_FROM="CRMPro <noreply@tudominio.com>"

# ===========================================
# WEBHOOKS
# ===========================================
# Secret para webhooks de tickets (por proyecto o global)
TICKET_WEBHOOK_SECRET="super-secret-token-min-32-chars"

# Secret para webhooks de GitHub (OBLIGATORIO en producción)
# Obtener de: GitHub repo > Settings > Webhooks > Secret
GITHUB_WEBHOOK_SECRET="your-github-webhook-secret"

# ===========================================
# RATE LIMITING (Upstash Redis - opcional)
# ===========================================
# Obtener de: https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ===========================================
# MONITORING (opcional)
# ===========================================
SENTRY_DSN=""

# ===========================================
# SECURITY (Mejoras de seguridad)
# ===========================================
# ENCRYPTION_SECRET: Para encriptar API keys en base de datos
# Generar con: openssl rand -hex 32 (o node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# IMPORTANTE: Mínimo 32 caracteres. NO cambiar después de encriptar datos.
ENCRYPTION_SECRET="your-encryption-secret-min-32-chars-here-generate-with-openssl"

# ALLOWED_CORS_ORIGINS: Orígenes adicionales permitidos para CORS (producción)
# Formato: Comma-separated list of origins
# Ejemplo: "https://claude.ai,https://example.com,https://app.example.com"
# Desarrollo: No necesario (localhost ya permitido automáticamente)
ALLOWED_CORS_ORIGINS=""
